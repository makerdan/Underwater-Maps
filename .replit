modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-settings-validation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "audit"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-heavy"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-fast"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-standard"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validation-lock.mjs -- pnpm run typecheck"

[[workflows.workflow]]
name = "lint"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validation-lock.mjs -- pnpm run lint"

[[workflows.workflow]]
name = "test-settings-validation"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validation-lock.mjs -- pnpm --filter @workspace/api-server run test:validation"

[[workflows.workflow]]
name = "test-e2e-palette"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validation-lock.mjs -- bash -c 'set -o pipefail; export E2E_WEB_PORT=3250 E2E_API_PORT=3261; mkdir -p .local/tmp && node scripts/kill-port-holders.mjs --e2e && npx playwright test tests/e2e/palette-cross-device-sync.spec.ts tests/e2e/onboarding-tour.spec.ts tests/e2e/settings-cross-device-sync.spec.ts tests/e2e/settings-save-buttons.spec.ts tests/e2e/zone-colour-server-sync.spec.ts tests/e2e/tooltips.spec.ts tests/e2e/adaptive-palette.spec.ts 2>&1 | tee .local/tmp/palette-e2e.log'"

[[workflows.workflow]]
name = "audit"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm audit --audit-level=moderate"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-heavy"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validation-lock.mjs -- node scripts/run-with-timeout.mjs aggregate -- node scripts/run-tier.mjs full"

[[workflows.workflow]]
name = "test-fast"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validation-lock.mjs -- node scripts/run-with-timeout.mjs tierFast -- node scripts/run-tier.mjs fast"

[[workflows.workflow]]
name = "test-standard"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validation-lock.mjs -- node scripts/run-with-timeout.mjs tierStandard -- node scripts/run-tier.mjs standard"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 480000

[[ports]]
localPort = 3150
externalPort = 3001

[[ports]]
localPort = 3151
externalPort = 3003
exposeLocalhost = true

[[ports]]
localPort = 3250
externalPort = 3002

[[ports]]
localPort = 8080
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 23993
externalPort = 3000

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-7d763d9b-7f87-4c5c-8bf1-317ab19f2828"

[userenv]

[userenv.shared]
GITHUB_REPO_URL = "https://github.com/makerdan/Underwater-Maps.git"

[userenv.development]
