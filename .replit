modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-unit"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-e2e"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-all"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-gpx-nmea-integration"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-fixture-freshness"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-unit"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run test:unit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run test:e2e"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-all"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck && pnpm run lint && pnpm run test:unit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-gpx-nmea-integration"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server exec vitest run --reporter=verbose src/__tests__/parser-gpx.test.ts src/__tests__/parser-nmea.test.ts"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-fixture-freshness"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/api-server/src/__tests__/fixtures/check-fixture-freshness.sh"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

[[ports]]
localPort = 3150
externalPort = 3001

[[ports]]
localPort = 3151
externalPort = 3003
exposeLocalhost = true

[[ports]]
localPort = 8080
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 23993
externalPort = 3000

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-7d763d9b-7f87-4c5c-8bf1-317ab19f2828"

[userenv]

[userenv.shared]
GITHUB_REPO_URL = "https://github.com/makerdan/Underwater-Maps.git"

[userenv.development]
E2E_AUTH_BYPASS = "1"
VITE_DEV_AUTH_BYPASS = "1"
