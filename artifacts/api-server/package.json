{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && export PORT=${PORT:-8080} && pnpm run build && pnpm run start",
    "dev:e2e": "export NODE_ENV=development && node ./build.mjs && node --enable-source-maps ./dist-e2e/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "start:e2e": "node --enable-source-maps ./dist-e2e/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:validation": "vitest run --config vitest.config.validation.ts",
    "fixtures:regen": "node src/__tests__/fixtures/generate.mjs && echo '' && echo 'Fixtures regenerated. Stage and commit the updated files:' && echo '  git add artifacts/api-server/src/__tests__/fixtures/' && echo \"  git commit -m 'chore: regenerate fixtures'\" && echo '' && echo 'To verify freshness (from repo root):' && echo '  bash artifacts/api-server/src/__tests__/fixtures/check-fixture-freshness.sh'"
  },
  "dependencies": {
    "@clerk/express": "^2.1.21",
    "@clerk/shared": "^4.13.1",
    "@google-cloud/storage": "^7.19.0",
    "@octokit/rest": "^22.0.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "@workspace/poe": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "geotiff": "^3.0.5",
    "google-auth-library": "^10.6.2",
    "h5wasm": "^0.10.2",
    "http-proxy-middleware": "^4.0.0",
    "laz-perf": "^0.0.7",
    "multer": "^2.1.1",
    "netcdfjs": "^4.0.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pngjs": "^7.0.0",
    "tar": "^7.5.16",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@types/tar": "^7.0.87",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "vitest": "^3.2.4"
  }
}
