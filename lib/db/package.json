{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "backfill:upload-dataset-ids": "tsx ./src/scripts/backfill-upload-dataset-ids.ts",
    "purge:null-userid-markers": "tsx ./src/scripts/purge-null-userid-markers.ts",
    "test:unit": "node ../../scripts/run-with-timeout.mjs libDbUnit --label \"lib-db test:unit\" -- vitest run"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
