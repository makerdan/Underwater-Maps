{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "postinstall": "pnpm --filter @workspace/api-spec run codegen:generate",
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "check:codegen": "pnpm --filter @workspace/api-spec run check:codegen",
    "check:codegen-stale": "node scripts/check-codegen-stale.mjs",
    "typecheck": "pnpm --filter @workspace/api-spec run codegen:generate && pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "eslint artifacts lib scripts tests eslint.config.mjs playwright.config.ts",
    "test:unit": "pnpm -r --if-present run test:unit",
    "test:validation": "pnpm --filter @workspace/api-server run test:validation && pnpm --filter @workspace/bathyscan run test:validation",
    "test:e2e": "node scripts/validation-lock.mjs -- pnpm run test:e2e:run",
    "test:e2e:run": "node scripts/kill-port-holders.mjs --e2e && node scripts/run-with-timeout.mjs e2e --label \"playwright e2e\" -- playwright test",
    "capture:help-screenshots": "node scripts/capture-help-screenshots.mjs",
    "docs": "node scripts/generate-api-docs.mjs",
    "check:docs-stale": "node scripts/generate-api-docs.mjs --check",
    "scaffold:catalog-tests": "node scripts/scaffold-catalog-tests.mjs",
    "check:catalog-coverage": "node scripts/scaffold-catalog-tests.mjs --check",
    "check:routes-documented": "pnpm --filter @workspace/api-server exec vitest run src/__tests__/routes-documented.test.ts",
    "check:lock-skill-sync": "node scripts/check-lock-skill-sync.mjs",
    "check:root-relative-api": "node --test scripts/__tests__/check-root-relative-api.test.mjs && node scripts/check-root-relative-api.mjs",
    "check:deps-suppression": "node scripts/check-deps-suppression.mjs",
    "check:runner-step-sync": "node scripts/check-runner-step-sync.mjs",
    "check:skip-count": "node scripts/check-skip-count.mjs",
    "check:ports": "node scripts/check-hardcoded-ports.mjs",
    "check:e2e-user-ids": "bash scripts/check-e2e-user-ids.sh",
    "check:e2e-panel-collapse": "bash scripts/check-e2e-panel-collapse.sh",
    "check:e2e-cjs-globals": "bash scripts/check-e2e-cjs-globals.sh",
    "check:fixture-freshness": "bash artifacts/api-server/src/__tests__/fixtures/check-fixture-freshness.sh",
    "check:schema-stale": "node scripts/check-schema-drift.mjs",
    "check:port-drift": "node scripts/check-port-drift.mjs",
    "check:audit": "node scripts/check-audit.mjs",
    "check:bare-pino-http-mock": "node scripts/check-bare-pino-http-mock.mjs",
    "check:font-scale": "node --test scripts/__tests__/check-font-scale.test.mjs && node scripts/check-font-scale.mjs",
    "check:mock-drift": "pnpm --filter @workspace/bathyscan exec vitest run src/__tests__/apiClientMockSentinel.test.ts src/__tests__/clerkBypassMockSentinel.test.ts && pnpm --filter @workspace/api-server exec vitest run src/__tests__/settings-schema-sync.test.ts src/__tests__/settings-coverage-sentinel.test.ts",
    "check:drift": "node scripts/check-drift.mjs",
    "test-all": "node scripts/run-with-timeout.mjs aggregate --label \"test-all\" -- node scripts/test-all-steps.mjs"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1": "^1.1.16",
      "brace-expansion@2": "^2.1.2",
      "brace-expansion@5": "^5.0.7",
      "tar@7": "^7.5.19",
      "js-yaml@4": "4.3.0",
      "esbuild@<0.25": "^0.25.0",
      "uuid@<11.1.1": "^11.1.1"
    }
  }
}
